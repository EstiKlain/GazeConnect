{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "camera-route": {
        "ClusterId": "camera-cluster",
        "Match": {
          "Path": "/api/camera/{**catch-all}"
        }
      },
      "aac-route": {
        "ClusterId": "aac-cluster",
        "Match": {
          "Path": "/api/aac/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "tts-route": {
        "ClusterId": "tts-cluster",
        "Match": {
          "Path": "/api/tts/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "camera-cluster": {
        "Destinations": {
          "camera-service": {
            "Address": "http://camerahub:5001"
          }
        }
      },
      "aac-cluster": {
        "Destinations": {
          "aac-service": {
            "Address": "http://aacboard:5002"
          }
        }
      },
      "users-cluster": {
        "Destinations": {
          "users-service": {
            "Address": "http://userprofile:5004"
          }
        }
      },
      "tts-cluster": {
        "Destinations": {
          "tts-service": {
            "Address": "http://ttsservice:5003"
          }
        }
      }
    }
  }
}